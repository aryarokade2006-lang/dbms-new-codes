-- Create EMP Table
CREATE TABLE Emp(
    emp_id NUMBER PRIMARY KEY,
    ename VARCHAR2(30),
    street VARCHAR2(30),
    city VARCHAR2(30)
);


-- Create Company Table
CREATE TABLE Company(
    c_id NUMBER PRIMARY KEY,
    cname VARCHAR2(30),
    city VARCHAR2(30)
);


-- Create Works Table
CREATE TABLE works(
    emp_id NUMBER,
    c_id NUMBER,
    ename VARCHAR2(30),
    cname VARCHAR2(30),
    sal NUMBER(10,2),
    FOREIGN KEY(emp_id) REFERENCES Emp(emp_id),
    FOREIGN KEY(c_id) REFERENCES Company(c_id)
);


-- Create Manager Table
CREATE TABLE Manager(
    mgr_id NUMBER PRIMARY KEY,
    mgrname VARCHAR2(30)
);



