---------------------------------------------------
-- i. Modify the database so that ABC is now in Pune
---------------------------------------------------

UPDATE Company
SET city='Pune'
WHERE cname='ABC';



---------------------------------------------------
-- ii. Give all managers of Mbank a 10% raise.
-- If salary > 20000, give only 3% raise.
---------------------------------------------------

UPDATE works
SET sal =
CASE
    WHEN sal > 20000 THEN sal + (sal*0.03)
    ELSE sal + (sal*0.10)
END
WHERE cname='Mbank';



---------------------------------------------------
-- iii. Find names of employees who work in Bosch
-- company in Pune
---------------------------------------------------

SELECT w.ename
FROM works w
JOIN Company c
ON w.c_id = c.c_id
WHERE c.cname='Bosch'
AND c.city='Pune';



---------------------------------------------------
-- iv. Delete all records in works table for
-- employees of SBC Company whose salary > 50000
---------------------------------------------------

DELETE FROM works
WHERE cname='SBC Company'
AND sal > 50000';



