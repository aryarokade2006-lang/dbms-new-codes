Create Customer and Account table and add rows shown below

customer table                                    account table            

CREATE TABLE customer(
c_id VARCHAR(5) PRIMARY KEY,
cname VARCHAR(20),
city VARCHAR(20)
);

CREATE TABLE account(
acc_no VARCHAR(5) PRIMARY KEY,
c_id VARCHAR(5),
acc_type VARCHAR(20),
amount NUMBER(10),

FOREIGN KEY(c_id)
REFERENCES customer(c_id)
);

