---------------------------------------------------
-- Create Stored Procedure proc_Grade
---------------------------------------------------

CREATE OR REPLACE PROCEDURE proc_Grade(
    p_roll IN NUMBER,
    p_name IN VARCHAR2,
    p_marks IN NUMBER
)
IS
    v_class VARCHAR2(30);
BEGIN

    IF p_marks <= 1500 AND p_marks >= 990 THEN
        v_class := 'Distinction';

    ELSIF p_marks BETWEEN 900 AND 989 THEN
        v_class := 'First Class';

    ELSIF p_marks BETWEEN 825 AND 899 THEN
        v_class := 'Higher Second Class';

    ELSE
        v_class := 'Fail';
    END IF;

    
    INSERT INTO Result
    VALUES(p_roll, p_name, v_class);

END;
/
    


---------------------------------------------------
-- PL/SQL Block to Call Procedure
---------------------------------------------------

BEGIN

    FOR rec IN (SELECT * FROM Stud_Marks)
    LOOP

        proc_Grade(rec.Roll,
                   rec.Name,
                   rec.Total_Marks);

    END LOOP;

END;
/
    


