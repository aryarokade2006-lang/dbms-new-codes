-- Create Stud_Marks Table

CREATE TABLE Stud_Marks(
    Roll NUMBER PRIMARY KEY,
    Name VARCHAR2(30),
    Total_Marks NUMBER
);



-- Create Result Table

CREATE TABLE Result(
    Roll NUMBER,
    Name VARCHAR2(30),
    Class VARCHAR2(30)
);



